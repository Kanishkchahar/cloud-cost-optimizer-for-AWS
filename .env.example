# ============================================================
# AWS Smart Cost Optimizer — Environment Configuration
# ============================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to git — it's in .gitignore.
# ============================================================

# --- AWS Credentials ---
AWS_ACCESS_KEY_ID=your_access_key_here
AWS_SECRET_ACCESS_KEY=your_secret_key_here
AWS_DEFAULT_REGION=us-east-1

# --- Budget Alert Settings ---
# Monthly waste threshold in USD — sends email when exceeded
BUDGET_THRESHOLD=50.00

# --- Email Notification Settings ---
# Use Gmail: enable "App Passwords" at https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password_here
ALERT_FROM=your_email@gmail.com
ALERT_TO=your_email@gmail.com

# --- Ollama AI Settings ---
OLLAMA_MODEL=phi3
OLLAMA_URL=http://localhost:11434/api/generate

# --- App Settings ---
SNAPSHOT_AGE_DAYS=30
EC2_CPU_THRESHOLD=5.0
DB_PATH=db/optimizer.db
